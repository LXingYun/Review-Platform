# AI
OPENAI_API_KEY=
OPENAI_API_KEYS=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_SEED=
AI_RETRY_MAX_ATTEMPTS=4
AI_RETRY_BASE_DELAY_MS=800
AI_KEY_COOLDOWN_MS=45000
AI_REQUEST_TIMEOUT_MS=90000

# Review execution
REVIEW_DEFAULT_CONSISTENCY_MODE=balanced
REVIEW_WORKER_CONCURRENCY=1
TENDER_CHAPTER_REVIEW_CONCURRENCY=3
TENDER_CHAPTER_REVIEW_MIN_CONCURRENCY=2
REVIEW_MIN_VISIBLE_DURATION_MS=500
REVIEW_GLOBAL_MAX_ACTIVE_TASKS=4
REVIEW_GLOBAL_DEGRADED_MAX_ACTIVE_TASKS=3
REVIEW_GLOBAL_SEVERE_MAX_ACTIVE_TASKS=1
REVIEW_GLOBAL_MAX_AI_INFLIGHT=24
REVIEW_GLOBAL_DEGRADED_AI_INFLIGHT=12
REVIEW_GLOBAL_MIN_AI_INFLIGHT=8
REVIEW_PER_TASK_MAX_AI_INFLIGHT=8
RUNTIME_HEALTH_SAMPLE_INTERVAL_MS=1000
RUNTIME_HEALTH_WINDOW_MS=600000
RUNTIME_DEGRADED_EVENT_LOOP_P95_MS=120
RUNTIME_SEVERE_EVENT_LOOP_P95_MS=250
RUNTIME_DEGRADED_TIMEOUT_RATE=0.02
RUNTIME_SEVERE_TIMEOUT_RATE=0.08
RUNTIME_DEGRADED_HEALTH_TIMEOUT_RATE=0.003
RUNTIME_SEVERE_HEALTH_TIMEOUT_RATE=0.01

# OCR
PADDLE_OCR_API_URL=
PADDLE_OCR_TOKEN=
